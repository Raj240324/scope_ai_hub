# =============================================================================
# SCOPE AI HUB — Backend Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Application ---
ENV=development
DEBUG=True
APP_NAME=SCOPE AI HUB API
APP_VERSION=1.0.0

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scope_ai_hub

# --- Email (Gmail SMTP) ---
# Generate an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nagarajan.webdev@gmail.com
SMTP_PASSWORD=
FROM_EMAIL=nagarajan.webdev@gmail.com
FROM_NAME=SCOPE AI HUB

# --- Admin ---
ADMIN_EMAIL=nagarajan.webdev@gmail.com

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Institute Branding (used in email templates) ---
INSTITUTE_NAME=SCOPE AI HUB
INSTITUTE_TAGLINE=Shaping the AI Generation
INSTITUTE_PHONE=+91 63839 80415
INSTITUTE_EMAIL=info@scopeaihub.com
INSTITUTE_WEBSITE=https://scopeaihub.com
INSTITUTE_ADDRESS=Chennai, Tamil Nadu, India

# --- Rate Limiting ---
RATE_LIMIT=5/minute
