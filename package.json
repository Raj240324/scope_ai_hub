{
  "name": "scopeaihub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-sitemap.js && node scripts/generate-csp-hashes.js",
    "prerender": "react-snap",
    "build:full": "npm run build && npm run prerender",
    "build:sitemap": "node scripts/generate-sitemap.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --production"
  },
  "dependencies": {
    "@sentry/react": "^10.40.0",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/postcss": "^4.1.18",
    "ajv": "^8.18.0",
    "animejs": "^4.3.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.577.0",
    "path-to-regexp": "^8.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "reactSnap": {
    "inlineCss": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "source": "dist",
    "crawl": false,
    "include": [
      "/",
      "/about",
      "/courses",
      "/admissions",
      "/reviews",
      "/faq",
      "/privacy-policy",
      "/terms-conditions",
      "/nda-policy",
      "/refund-policy",
      "/disclaimer",
      "/careers/join-as-trainer",
      "/careers/trainers",
      "/sitemap",
      "/courses/generative-ai-prompt-engineering",
      "/courses/full-stack-data-science-ai",
      "/courses/machine-learning-mlops",
      "/courses/nlp-large-language-models",
      "/courses/computer-vision-deep-learning",
      "/courses/applied-data-analytics",
      "/courses/python-for-ai-beginners",
      "/courses/ai-for-business-leaders",
      "/404"
    ]
  }
}
