# ─── Frontend (VITE_ prefix = exposed in browser bundle) ─────────
# Google reCAPTCHA v2 Site Key (public, safe for frontend)
VITE_RECAPTCHA_SITE_KEY=

# Sentry DSN for frontend error monitoring (public DSN, safe)
VITE_SENTRY_DSN=

# Tawk.to live chat widget IDs
VITE_TAWK_PROPERTY_ID=
VITE_TAWK_WIDGET_ID=

# ─── Backend Only (Vercel Dashboard → Environment Variables) ─────
# Google reCAPTCHA v2 Secret Key (MUST be kept server-side only)
RECAPTCHA_SECRET_KEY=

# Brevo (Sendinblue) API Key for transactional emails & CRM
BREVO_API_KEY=

# Supabase (server-side only — NEVER expose service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Origin & hostname validation
ALLOWED_ORIGINS=http://localhost:5173,https://scope-ai-hub.vercel.app,https://scopeaihub.com
ALLOWED_HOSTNAME=scopeaihub.com